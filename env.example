# ================================================================
# 🔒 TrackLock - Variáveis de Ambiente
# ================================================================
# 
# ⚠️ IMPORTANTE:
# 1. COPIE este arquivo e renomeie para .env
# 2. Nunca compartilhe o arquivo .env
# 3. Adicione .env no .gitignore
# 4. Preencha com suas NOVAS chaves (não use as antigas!)
#
# ================================================================

# ==================== SERVIDOR ====================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ==================== AUTH ====================
# Gere uma string aleatória forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque_por_uma_string_secreta_longa_e_aleatoria

# ==================== LIGHTHOUSE ====================
# Obtenha em: https://app.lighthouse.storage/
# Dashboard → API Keys → Criar nova chave
LIGHTHOUSE_API_KEY=sua_nova_chave_lighthouse_aqui
LIGHTHOUSE_ENDPOINT=https://api.lighthouse.storage

# ==================== INFURA ====================
# Obtenha em: https://app.infura.io/
# Create Project → Ethereum → Mainnet
INFURA_API_KEY=sua_nova_chave_infura_aqui
INFURA_API_SECRET=seu_secret_infura_aqui
INFURA_ENDPOINT=https://mainnet.infura.io/v3/sua_nova_chave_infura_aqui

# ==================== ETHEREUM ====================
# Endereço da sua carteira Ethereum
ETHEREUM_ADDRESS=0xSeuEndereco

# ⚠️ CHAVE PRIVADA: NUNCA compartilhe, NUNCA commite no Git!
ETHEREUM_PRIVATE_KEY=sua_chave_privada_aqui

# Rede: mainnet | sepolia | ganache
ETHEREUM_NETWORK=mainnet

# Endereço do Smart Contract implantado
CONTRACT_ADDRESS=0xEnderecoDoContrato

# ==================== BANCO DE DADOS (opcional) ====================
# Se usar MongoDB
MONGODB_URI=mongodb://localhost:27017/tracklock

# ================================================================
# 📋 CHECKLIST ANTES DE RODAR:
# ================================================================
# ✅ Gerou novas chaves Lighthouse?
# ✅ Gerou novas chaves Infura?
# ✅ Preencheu ETHEREUM_ADDRESS?
# ✅ Preencheu ETHEREUM_PRIVATE_KEY?
# ✅ Arquivo .env está em .gitignore?
# ✅ Nunca comitou o .env?
# 
# Se sim, você está seguro! 🔐
# ================================================================
